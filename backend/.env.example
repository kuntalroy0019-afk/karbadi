# Copy to .env and fill in. All values have safe dev defaults if omitted.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOW_ALL=true

# --- Database (leave POSTGRES_DB blank to use SQLite) ---
# POSTGRES_DB=karbadi
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# --- Cloudinary (media/image storage) ---
# Provide EITHER the single URL or the three discrete vars. If unset, image
# uploads fall back to local MEDIA_ROOT so the project still runs offline.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Integrations: keep mocks ON until real credentials are supplied ---
USE_MOCK_COURIERS=true
USE_MOCK_OEM=true

# Warehouse / pickup origin (used for serviceability + bookings)
PICKUP_LOCATION=Primary       # must match a pickup location name in your Shiprocket dashboard
PICKUP_PINCODE=400001
PICKUP_CITY=Mumbai
PICKUP_STATE=Maharashtra

# Shiprocket (Module 1) — set USE_MOCK_COURIERS=false to go live
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external

# Shree Maruti Courier (Module 1)
SHREE_MARUTI_API_KEY=
SHREE_MARUTI_CLIENT_ID=
SHREE_MARUTI_BASE_URL=https://api.shreemaruticourier.com

# Oriparts OEM catalogue (Module 3)
ORIPARTS_API_KEY=
ORIPARTS_BASE_URL=https://api.oriparts.com
